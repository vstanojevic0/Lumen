<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Lumen.Controls.EditSliderRow"
             x:Name="Root">
  <StackPanel Spacing="6">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="{Binding #Root.Label}" Classes="slider-label" />
      <TextBlock Grid.Column="1" Text="{Binding #Root.ValueDisplay}" Classes="slider-value" />
    </Grid>
    <Slider Minimum="{Binding #Root.Minimum}"
            Maximum="{Binding #Root.Maximum}"
            Value="{Binding #Root.Value, Mode=TwoWay}"
            Classes="edit-slider" />
  </StackPanel>
</UserControl>
