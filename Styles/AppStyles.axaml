<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:Lumen.Controls">
  <Style Selector="Window">
    <Setter Property="Background" Value="#080C12" />
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="Foreground" Value="#E8EDF5" />
  </Style>

  <!-- Glass panels (match web demo) -->
  <Style Selector="Border.glass">
    <Setter Property="Background" Value="#B8121820" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <Style Selector="Border.panel-glass">
    <Setter Property="Background" Value="#B8121820" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
  </Style>

  <Style Selector="Border.sidebar-modern">
    <Setter Property="Background" Value="#B8121820" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <Style Selector="Border.sidebar-header">
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Border.sidebar-footer">
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
  </Style>

  <Style Selector="Border.brand-mark">
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Color="#3B9BFF" Offset="0" />
        <GradientStop Color="#2A6FD4" Offset="1" />
      </LinearGradientBrush>
    </Setter>
  </Style>

  <Style Selector="TextBlock.sidebar-section-label">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Opacity" Value="0.35" />
    <Setter Property="LetterSpacing" Value="1.5" />
  </Style>

  <Style Selector="Button.sidebar-nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="2,1" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Foreground" Value="#B3FFFFFF" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.sidebar-nav:pointerover">
    <Setter Property="Background" Value="#0FFFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.sidebar-nav.active">
    <Setter Property="Background" Value="#263B9BFF" />
    <Setter Property="BorderBrush" Value="#663B9BFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.sidebar-nav.active TextBlock.nav-icon">
    <Setter Property="Foreground" Value="#7EB8FF" />
  </Style>

  <Style Selector="TextBlock.nav-icon">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Opacity" Value="0.45" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Width" Value="18" />
  </Style>

  <Style Selector="Button.sidebar-row">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Margin" Value="2,0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Foreground" Value="#A6FFFFFF" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.sidebar-row:pointerover">
    <Setter Property="Background" Value="#0FFFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.sidebar-action">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Foreground" Value="#80FFFFFF" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Button.sidebar-action:pointerover">
    <Setter Property="Background" Value="#14FFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Border.count-badge">
    <Setter Property="Background" Value="#14FFFFFF" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="MinWidth" Value="24" />
  </Style>

  <Style Selector="Border.count-badge TextBlock">
    <Setter Property="Foreground" Value="#8CFFFFFF" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="10" />
  </Style>

  <Style Selector="Button.sidebar-nav.active Border.count-badge">
    <Setter Property="Background" Value="#333B9BFF" />
  </Style>

  <Style Selector="Button.sidebar-nav.active Border.count-badge TextBlock">
    <Setter Property="Foreground" Value="#B8D4FF" />
  </Style>

  <Style Selector="Border.toolbar-glass">
    <Setter Property="Background" Value="#B8121820" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="MinHeight" Value="56" />
  </Style>

  <Style Selector="TextBox.search">
    <Setter Property="Background" Value="#40000000" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="38" />
  </Style>

  <Style Selector="ComboBox.workspace-mode">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="MinWidth" Value="100" />
  </Style>

  <Style Selector="Button.toolbar-icon">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="Foreground" Value="#99FFFFFF" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <Style Selector="Button.toolbar-icon:pointerover">
    <Setter Property="Background" Value="#1AFFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.toolbar-icon.active">
    <Setter Property="Background" Value="#263B9BFF" />
    <Setter Property="BorderBrush" Value="#663B9BFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Border.zoom-box">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="8,6" />
  </Style>

  <Style Selector="Border.edit-canvas">
    <Setter Property="Background" Value="#060910" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Border.filmstrip-bar">
    <Setter Property="Background" Value="#CC0F141C" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="Border.photo-card">
    <Setter Property="Background" Value="#141A22" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="ctrl|LazyThumbnailHost.photo-card.selected">
    <Setter Property="BorderBrush" Value="#3B9BFF" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="ctrl|LazyThumbnailHost.selected">
    <Setter Property="BorderBrush" Value="#3B9BFF" />
    <Setter Property="BorderThickness" Value="3" />
  </Style>

  <Style Selector="Border.filmstrip-item">
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Border.filmstrip-item.selected">
    <Setter Property="BorderBrush" Value="#3B9BFF" />
  </Style>

  <Style Selector="Expander.edit-expander">
    <Setter Property="Background" Value="#121820" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Foreground" Value="#E8EDF5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Border.tone-curve-card">
    <Setter Property="Background" Value="#0A1018" />
    <Setter Property="BorderBrush" Value="#14FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="TextBlock.slider-label">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Opacity" Value="0.75" />
  </Style>

  <Style Selector="TextBlock.slider-value">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="#7EB8FF" />
    <Setter Property="FontFeatures" Value="tnum" />
  </Style>

  <Style Selector="Button.preset-chip">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,10" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="#B3FFFFFF" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.preset-chip:pointerover">
    <Setter Property="Background" Value="#1AFFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.action-chip">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="BorderBrush" Value="#1AFFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="#99FFFFFF" />
  </Style>

  <Style Selector="Button.action-chip:pointerover">
    <Setter Property="Background" Value="#1AFFFFFF" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.action-chip.favorite-on">
    <Setter Property="Background" Value="#26FF4444" />
    <Setter Property="BorderBrush" Value="#66FF6666" />
    <Setter Property="Foreground" Value="#FFAAAA" />
  </Style>

  <Style Selector="Button.nav-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Foreground" Value="#CCFFFFFF" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Button.nav-item:pointerover">
    <Setter Property="Background" Value="#18FFFFFF" />
  </Style>

  <Style Selector="Button.nav-item.active">
    <Setter Property="Background" Value="#243858" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#3B9BFF" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="#4AA5FF" />
  </Style>

  <Style Selector="Slider.edit-slider">
    <Setter Property="Foreground" Value="#3B9BFF" />
  </Style>

  <Style Selector="ListBox.sidebar-folder-list">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="ListBox.sidebar-folder-list ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.sidebar-folder-list ListBoxItem:selected">
    <Setter Property="Background" Value="#1A2A42" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <Style Selector="ListBox.filmstrip ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.meta-pill">
    <Setter Property="Background" Value="#0DFFFFFF" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,6" />
  </Style>
</Styles>
